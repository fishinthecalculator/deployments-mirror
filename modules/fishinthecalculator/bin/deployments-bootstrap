#!/usr/bin/env bash

set -eu

DEPLOYMENTS_PATH="/tmp/guix-deployments/modules"
DEPLOYMENTS_BIN="${DEPLOYMENTS_PATH}/fishinthecalculator/common/bin"

cd /tmp && rm -rf guix-deployments && guix shell git -- git https://codeberg.org/fishinthecalculator/guix-deployments.git
export PATH="${DEPLOYMENTS_BIN}:${PATH}"

sudo "${DEPLOYMENTS_BIN}/start-nonguix-daemon"

sudo "${DEPLOYMENTS_BIN}/reconfigure" -L "${DEPLOYMENTS_PATH}"

exit 0
