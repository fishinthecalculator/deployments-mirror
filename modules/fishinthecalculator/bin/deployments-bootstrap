#!/usr/bin/env bash

set -eu

DEPLOYMENTS_PATH="/tmp/guix-deployments/modules"
DEPLOYMENTS_BIN="${DEPLOYMENTS_PATH}/fishinthecalculator/bin"

cd /tmp && rm -rf guix-deployments && guix shell git -- git clone https://codeberg.org/fishinthecalculator/guix-deployments.git
export PATH="${DEPLOYMENTS_BIN}:${PATH}"

guix_host="$(hostname)"
sudo guix system reconfigure -L "${DEPLOYMENTS_PATH}" -e "(@ (fishinthecalculator ${guix_host} system install) ${guix_host}-stage0)"
sudo herd stop guix-daemon
sudo herd start guix-daemon

sudo "${DEPLOYMENTS_BIN}/reconfigure" -L "${DEPLOYMENTS_PATH}"

exit 0
