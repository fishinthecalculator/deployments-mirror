[user]
	email = therewasa@fishinthecalculator.me
	name = Giacomo Leidi
	signingkey = 8D1060B96BB8292E829B7249AED41CC193B701E2
[core]
	editor = emacs
[sendemail]
	smtpServer = smtp.mailbox.org
	smtpuser = therewasa@fishinthecalculator.me
	smtpencryption = tls
	smtpserverport = 587
[pull]
	rebase = true
[merge]
	tool = meld
[mergetool "meld"]
	cmd = meld "$LOCAL" "$MERGED" "$REMOTE" --output "$MERGED"
	keepBackup = false
[diff]
	tool = meld
[difftool]
	prompt = false
[difftool "meld"]
	cmd = meld "$LOCAL" "$REMOTE"
[color]
	ui = auto
[commit]
	gpgsign = true

[alias]
	staash = "stash --all"
	bblame = "blame -w -C -C -C"

# REuse REcorded REsolution
[rerere]
	enabled = true

[column]
	ui = auto

[branch]
	sort = -committerdate
