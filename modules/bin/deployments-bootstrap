#!/usr/bin/env bash

set -eu

DEPLOYMENTS_PATH="/tmp/guix-deployments/modules/bin"

cd /tmp && guix shell git -- git clone https://gitlab.com/orang3/guix-deployments
export PATH="${DEPLOYMENTS_PATH}:${PATH}"

sudo "${DEPLOYMENTS_PATH}/start-nonguix-daemon"

sudo "${DEPLOYMENTS_PATH}/reconfigure"

exit 0
