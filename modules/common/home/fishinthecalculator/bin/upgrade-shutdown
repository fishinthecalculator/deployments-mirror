#!/usr/bin/env bash

[[ "$(id -u)" -eq 0 ]] && echo "ERROR: This script can not run as root!" && exit 1

myself="$USER"

sudo bash -c "
set -u

[[ \"$#\" -eq 1 ]] && su ${myself} -l -c 'cleanup'

su ${myself} -l -c 'upall'

~${myself}/.guix-home/profile/bin/reconfigure

su ${myself} -l -c 'guix gc'

~${myself}/.guix-home/profile/bin/unload

shutdown
"
